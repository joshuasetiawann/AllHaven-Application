# AllHaven production environment (copy to .env.prod; NEVER commit the real file).
# Used by: docker compose -f docker-compose.prod.yml --env-file .env.prod up -d --build

# Your domain (DNS A record must point at this server).
DOMAIN=yourdomain.com

# --- Database ---
POSTGRES_USER=allhaven
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DB=allhaven

# --- Security (generate strong random values) ---
# python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-long-random
SETTINGS_ENCRYPTION_KEY=change-me-long-random-32+chars

# --- Optional defaults (the web Settings UI can also configure these) ---
OLLAMA_BASE_URL=
