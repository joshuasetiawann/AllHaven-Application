<?xml version="1.0" encoding="utf-8"?>
<!--
  AllHaven mobile network security policy.

  Why cleartext is permitted: AllHaven is a PRIVATE, local-first command center.
  From mobile, the backend is reached over the user's own Tailscale tailnet, and
  the Settings → Backend Bridge UI explicitly offers a Tailscale-private address
  of the form http://100.x.y.z:8000 (plain HTTP). On Android 9+ (this app targets
  API 36) cleartext is blocked by default, so without this the user-configured
  http:// Tailscale IP silently fails — one of the root causes of "mobile shows
  no data". Tailscale already encrypts/authenticates all traffic at the WireGuard
  layer between your devices, and these addresses are only reachable inside your
  own tailnet, so cleartext here does not cross the public internet.

  Recommended secure default: use Tailscale Serve (HTTPS, e.g.
  https://desktop.tailnet.ts.net) — that needs no cleartext at all. This policy
  exists so the plain-HTTP Tailscale-IP path also works for users who prefer it.
  To harden a build, set cleartextTrafficPermitted="false" and use HTTPS Serve.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
