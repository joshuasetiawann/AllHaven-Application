# =========================================================================
# AllHaven Command Center — example environment configuration
# Copy to `.env` and adjust. NEVER commit a real `.env`.
# Placeholder values keep optional integrations in a "not configured" state.
#

# HOW .env CONNECTS TO THE WEB SETTINGS PAGE:
#   * The backend reads this repo-root `.env` (and backend/.env if present).
#   * Values here are DEFAULTS: e.g. setting OPENAI_API_KEY or OLLAMA_BASE_URL
#     makes that provider show as "configured" in Settings → AI Providers,
#     even before you type anything in the web UI.
#   * Anything you SAVE in the web Settings is stored encrypted in the database
#     (per workspace) and OVERRIDES these defaults. The web never writes secrets
#     back into this file. Edit .env for machine-wide defaults; use the web UI
#     for per-workspace, encrypted config. Real env vars override the file.
# =========================================================================


# --- Application ---
APP_NAME=AllHaven Command Center
APP_ENV=local
API_V1_PREFIX=/api/v1
# Local/dev exposes Swagger/OpenAPI by default; production/staging defaults off.
# API_DOCS_ENABLED=true
# Local/dev allows private LAN/Tailscale integration URLs for Ollama/n8n. Production
# defaults off to prevent SSRF unless you explicitly trust the deployment/users.
# ALLOW_PRIVATE_INTEGRATION_URLS=true
APP_TIMEZONE=Asia/Jakarta
# Comma-separated list of allowed frontend origins.
BACKEND_CORS_ORIGINS=http://localhost:3000

# --- Service ports (set by the setup wizard; editable in Settings → System Control) ---
FRONTEND_PORT=3000
BACKEND_PORT=8000

# --- System Control (desktop control panel + local Haven agent) ---
# Master switch for the in-app Start/Stop/Restart controls. The API also requires
# APP_ENV=local, so a production deployment never exposes service control.
SYSTEM_CONTROL_ENABLED=true
# Localhost-only port the Haven control agent listens on (127.0.0.1).
HAVEN_AGENT_PORT=8765

# --- Auth / security (local MVP auth boundary) ---
# Generate a strong value, e.g.: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-to-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=1440
JWT_ALGORITHM=HS256

# --- Database (PostgreSQL) ---
POSTGRES_USER=allhaven
POSTGRES_PASSWORD=allhaven
POSTGRES_DB=allhaven
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# If empty, DATABASE_URL is assembled from the POSTGRES_* values above.
DATABASE_URL=postgresql+psycopg://allhaven:allhaven@localhost:5432/allhaven

# --- Secret storage (encryption at rest for web-configured credentials) ---
# Use a long random value in production. Local MVP scheme; rotate via KMS later.
SETTINGS_ENCRYPTION_KEY=change-me-32-byte-development-key

# --- Multi-provider AI system ---
AI_DEFAULT_PROVIDER=ollama
AI_ALLOW_EXTERNAL_PROVIDERS=false
AI_DEFAULT_PRIVACY_MODE=local_private

# Local AI (no API key needed)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=

# External AI providers (disabled by default; configurable from the web UI too).
# Leave blank to keep "not configured" — never commit real keys.
OPENAI_API_KEY=
OPENAI_DEFAULT_MODEL=
ANTHROPIC_API_KEY=
ANTHROPIC_DEFAULT_MODEL=
GEMINI_API_KEY=
GEMINI_DEFAULT_MODEL=
GROK_API_KEY=
GROK_DEFAULT_MODEL=
BLACKBOX_API_KEY=
BLACKBOX_DEFAULT_MODEL=
# Cursor AI uses a Cursor/OpenAI-compatible gateway URL for AllHaven chat.
CURSOR_API_KEY=
CURSOR_DEFAULT_MODEL=
CURSOR_BASE_URL=
DEEPSEEK_API_KEY=
DEEPSEEK_DEFAULT_MODEL=
QWEN_API_KEY=
QWEN_DEFAULT_MODEL=
# Legacy single OpenRouter key (kept for backward compatibility; maps to slot 1).
OPENROUTER_API_KEY=
OPENROUTER_DEFAULT_MODEL=
# Six independent OpenRouter agents (each its own key + default model). All
# six appear in Settings → AI Providers and the AI Chat multi-agent selector.
# Suggested roles: 1 Main Assistant · 2 Reasoning/Planner · 3 Critic/Reviewer
#                  4 Coding/Technical · 5 Research/Long Context · 6 Synthesizer.
OPENROUTER_1_API_KEY=
OPENROUTER_1_DEFAULT_MODEL=
OPENROUTER_2_API_KEY=
OPENROUTER_2_DEFAULT_MODEL=
OPENROUTER_3_API_KEY=
OPENROUTER_3_DEFAULT_MODEL=
OPENROUTER_4_API_KEY=
OPENROUTER_4_DEFAULT_MODEL=
OPENROUTER_5_API_KEY=
OPENROUTER_5_DEFAULT_MODEL=
OPENROUTER_6_API_KEY=
OPENROUTER_6_DEFAULT_MODEL=

# --- Optional tool integrations ---
# Leave blank / placeholder to keep them "not configured" (no fake success).
N8N_BASE_URL=
N8N_API_KEY=
SUPABASE_URL=
SUPABASE_ANON_KEY=
# Set to "supabase" ONLY when running `alembic upgrade head` against the Supabase
# database (enables RLS + policies). Leave empty for the local Postgres database.
ALLHAVEN_DB_TARGET=
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_REDIRECT_URI=
DRIVE_STORAGE_PROVIDER=
# Local Drive storage root for uploaded file bytes (defaults to <repo>/var/drive).
DRIVE_STORAGE_DIR=
DRIVE_MAX_UPLOAD_MB=250

# --- Google OAuth foundation (login + scoped API access) ---
# Configurable from the web UI too (Settings → Connected Tools → Google OAuth).
# Minimal scopes by default (openid, email, profile). Sensitive scopes need consent
# and may require Google app verification in production.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/oauth/google/callback

# --- Frontend ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1

# Supabase GoTrue JWT secret (Dashboard > Settings > API > JWT Secret). Set this so the
# mobile app (logs in via Supabase) can reach desktop-only Backend Bridge features
# (Settings, n8n, Ollama, system). Empty = Supabase bearer auth disabled.
SUPABASE_JWT_SECRET=
