# =========================================================================
# CoreOS Command Center — example environment configuration
# Copy to `.env` and adjust. NEVER commit a real `.env`.
# Placeholder values keep optional integrations in a "not configured" state.
#
# HOW .env CONNECTS TO THE WEB SETTINGS PAGE:
#   * The backend reads this repo-root `.env` (and backend/.env if present).
#   * Values here are DEFAULTS: e.g. setting OPENAI_API_KEY or OLLAMA_BASE_URL
#     makes that provider show as "configured" in Settings → AI Providers,
#     even before you type anything in the web UI.
#   * Anything you SAVE in the web Settings is stored encrypted in the database
#     (per workspace) and OVERRIDES these defaults. The web never writes secrets
#     back into this file. Edit .env for machine-wide defaults; use the web UI
#     for per-workspace, encrypted config. Real env vars override the file.
# =========================================================================

# --- Application ---
APP_NAME=CoreOS Command Center
APP_ENV=local
API_V1_PREFIX=/api/v1
# Comma-separated list of allowed frontend origins.
BACKEND_CORS_ORIGINS=http://localhost:3000

# --- Auth / security (local MVP auth boundary) ---
# Generate a strong value, e.g.: python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-to-a-long-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=1440
JWT_ALGORITHM=HS256

# --- Database (PostgreSQL) ---
POSTGRES_USER=coreos
POSTGRES_PASSWORD=coreos
POSTGRES_DB=coreos
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# If empty, DATABASE_URL is assembled from the POSTGRES_* values above.
DATABASE_URL=postgresql+psycopg://coreos:coreos@localhost:5432/coreos

# --- Secret storage (encryption at rest for web-configured credentials) ---
# Use a long random value in production. Local MVP scheme; rotate via KMS later.
SETTINGS_ENCRYPTION_KEY=change-me-32-byte-development-key

# --- Multi-provider AI system ---
AI_DEFAULT_PROVIDER=ollama
AI_ALLOW_EXTERNAL_PROVIDERS=false
AI_DEFAULT_PRIVACY_MODE=local_private

# Local AI (no API key needed)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=

# External AI providers (disabled by default; configurable from the web UI too).
# Leave blank to keep "not configured" — never commit real keys.
OPENAI_API_KEY=
OPENAI_DEFAULT_MODEL=
ANTHROPIC_API_KEY=
ANTHROPIC_DEFAULT_MODEL=
GEMINI_API_KEY=
GEMINI_DEFAULT_MODEL=
GROK_API_KEY=
GROK_DEFAULT_MODEL=
BLACKBOX_API_KEY=
BLACKBOX_DEFAULT_MODEL=
# Legacy single OpenRouter key (kept for backward compatibility; maps to slot 1).
OPENROUTER_API_KEY=
OPENROUTER_DEFAULT_MODEL=
# Three independent OpenRouter agents (each its own key + default model). All
# three appear in Settings → AI Providers and the AI Chat multi-agent selector.
OPENROUTER_1_API_KEY=
OPENROUTER_1_DEFAULT_MODEL=
OPENROUTER_2_API_KEY=
OPENROUTER_2_DEFAULT_MODEL=
OPENROUTER_3_API_KEY=
OPENROUTER_3_DEFAULT_MODEL=

# --- Optional tool integrations ---
# Leave blank / placeholder to keep them "not configured" (no fake success).
N8N_BASE_URL=
N8N_API_KEY=
SUPABASE_URL=
SUPABASE_ANON_KEY=
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_REDIRECT_URI=
WEATHER_API_KEY=
WEATHER_PROVIDER=
DRIVE_STORAGE_PROVIDER=
# Local Drive storage root for uploaded file bytes (defaults to <repo>/var/drive).
DRIVE_STORAGE_DIR=

# --- Google OAuth foundation (login + scoped API access) ---
# Configurable from the web UI too (Settings → Connected Tools → Google OAuth).
# Minimal scopes by default (openid, email, profile). Sensitive scopes need consent
# and may require Google app verification in production.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/oauth/google/callback

# --- Frontend ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
