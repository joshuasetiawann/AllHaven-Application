# AllHaven production environment (copy to .env.prod; NEVER commit the real file).
# Used by: docker compose -f docker-compose.prod.yml --env-file .env.prod up -d --build

# Your domain (DNS A record must point at this server).
DOMAIN=yourdomain.com

# Local timezone used for deterministic AI answers such as current time/date.
APP_TIMEZONE=Asia/Jakarta

# --- Database ---
POSTGRES_USER=allhaven
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DB=allhaven

# --- Security (generate strong random values) ---
# python -c "import secrets; print(secrets.token_urlsafe(48))"
# REQUIRED: the backend refuses to start in production with the dev default or
# a SECRET_KEY shorter than 32 characters.
SECRET_KEY=change-me-long-random
SETTINGS_ENCRYPTION_KEY=change-me-long-random-32+chars

# Browser session lifetime in days (HttpOnly cookie; refresh rotates+extends).
SESSION_TTL_DAYS=7
# Per-IP POST cap per minute on /auth/* (login/register/refresh). Single-instance
# in-memory limiter; ALSO rate-limit at your gateway if you run multiple replicas.
AUTH_RATE_LIMIT_PER_MINUTE=10

# --- Optional defaults (the web Settings UI can also configure these) ---
OLLAMA_BASE_URL=

DRIVE_MAX_UPLOAD_MB=250
